# Hugging Faceでfine-grained tokenを作り、
# "Make calls to Inference Providers" 権限を付けてください。
HF_TOKEN = "hf_xxxxxxxxxxxxxxxxxxxx"

# 現在の既定モデル。提供状況が変わったらSecretsだけを書き換えます。
MODEL = "google/gemma-4-26B-A4B-it:cheapest"

# OpenAI互換APIへ差し替える場合だけ変更します。
BASE_URL = "https://router.huggingface.co/v1"

# 任意です。Streamlit側の非公開設定に加える第二の入口制限です。
APP_PASSWORD = "change-this-password"
